{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
  		"request": "launch",
			"name": "Import Legislators",
			"runtimeArgs": ["-r", "ts-node/register"],
			"args": ["${workspaceFolder}/packages/importer/main.ts", "--command", "legislators"],
			"cwd": "${workspaceFolder}",
			"env": {
				"TS_NODE_PROJECT": "${workspaceFolder}/packages/importer/tsconfig.json"
			}
		},
		{
      "command": "npm run dev --workspace=@my-fat-senator/my-fat-senator",
      "name": "Run npm run dev",
      "request": "launch",
      "type": "node-terminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Attach by Process ID",
      "processId": "${command:PickProcess}",
      "request": "attach",
      "skipFiles": ["<node_internals>/**"],
      "type": "node"
    }
	]
}